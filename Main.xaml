                                        <ui:InvokeCode ContinueOnError="{x:Null}" Code="Try&#xA;    ' ── No Invoice: uppercase + trim ──&#xA;    outNoInv = rawNoInv.Trim.ToUpper&#xA;&#xA;&#x9;' Bersihkan suffix waktu kalau ada (misal &quot;06/07/2026 00:00:00&quot; → &quot;06/07/2026&quot;)&#xA;&#x9;' Ambil tanggal, buang suffix waktu kalau ada&#xA;Dim tgl As String = rawTanggal.Trim&#xA;If tgl.Contains(&quot; &quot;) Then tgl = tgl.Split(New Char(){Convert.ToChar(32)})(0).Trim&#xA;&#xA;' Standarkan ke dd/mm/yyyy&#xA;Dim mYMD = System.Text.RegularExpressions.Regex.Match(tgl, &quot;^(\d{4})-(\d{2})-(\d{2})$&quot;)&#xA;Dim mDMY = System.Text.RegularExpressions.Regex.Match(tgl, &quot;^(\d{2})-(\d{2})-(\d{4})$&quot;)&#xA;Dim mSlash = System.Text.RegularExpressions.Regex.Match(tgl, &quot;^(\d{2})/(\d{2})/(\d{4})$&quot;)&#xA;If mYMD.Success Then&#xA;    outTanggal = mYMD.Groups(3).Value &amp; &quot;/&quot; &amp; mYMD.Groups(2).Value &amp; &quot;/&quot; &amp; mYMD.Groups(1).Value&#xA;ElseIf mDMY.Success Then&#xA;    outTanggal = mDMY.Groups(1).Value &amp; &quot;/&quot; &amp; mDMY.Groups(2).Value &amp; &quot;/&quot; &amp; mDMY.Groups(3).Value&#xA;ElseIf mSlash.Success Then&#xA;    outTanggal = tgl&#xA;Else&#xA;    outTanggal = tgl&#xA;End If&#xA;&#xA;    ' ── Customer: PT tetap uppercase, kata lain capitalize ──&#xA;    Dim custWords = rawCustomer.Trim.Split(New Char(){Convert.ToChar(32)}, StringSplitOptions.RemoveEmptyEntries)&#xA;    Dim custResult As New System.Text.StringBuilder()&#xA;    For Each w As String In custWords&#xA;        If custResult.Length &gt; 0 Then custResult.Append(&quot; &quot;)&#xA;        If w.ToUpper = &quot;PT&quot; OrElse w.ToUpper = &quot;CV&quot; OrElse w.ToUpper = &quot;TBK&quot; Then&#xA;            custResult.Append(w.ToUpper)&#xA;        Else&#xA;            custResult.Append(w.Substring(0,1).ToUpper &amp; If(w.Length &gt; 1, w.Substring(1).ToLower, &quot;&quot;))&#xA;        End If&#xA;    Next&#xA;    outCustomer = custResult.ToString.Tr