                    <ui:InvokeCode ContinueOnError="{x:Null}" Code="Try&#xA;&#x9;Console.WriteLine(&quot;=== ISI pdfText ===&quot;)&#xA;&#x9;Console.WriteLine(If(pdfText Is Nothing, &quot;NULL / NOTHING&quot;, pdfText))&#xA;&#x9;Console.WriteLine(&quot;=== PANJANG: &quot; &amp; If(pdfText Is Nothing, &quot;NULL&quot;, pdfText.Length.ToString) &amp; &quot; karakter ===&quot;)&#xA;    Dim lines As String() = pdfText.Split(New Char() {Convert.ToChar(10), Convert.ToChar(13)}, StringSplitOptions.RemoveEmptyEntries)&#xA;    Dim normalized As New System.Text.StringBuilder()&#xA;    For Each line As String In lines&#xA;        Dim t As String = line.Trim&#xA;        If System.Text.RegularExpressions.Regex.IsMatch(t, &quot;^\d+\s+\S&quot;) Then&#xA;            normalized.AppendLine(t)&#xA;        ElseIf normalized.Length &gt; 0 AndAlso t.Length &gt; 0 Then&#xA;            normalized.Remove(normalized.Length - 2, 2)&#xA;            normalized.Append(&quot; &quot; &amp; t &amp; System.Environment.NewLine)&#xA;        End If&#xA;    Next&#xA;    Dim cleanText As String = normalized.ToString()&#xA;    Dim pattern As String = &quot;(\d+)\s+(.+?)\s+(\d+)\s+(Unit|Pcs|Set|Kg|Ltr|Buah|Meter|Rol|Box|Ls)\s+([\d,\.]+)\s+([\d,\.]+)&quot;&#xA;    Dim matches As System.Text.RegularExpressions.MatchCollection = System.Text.RegularExpressions.Regex.Matches(cleanText, pattern, System.Text.RegularExpressions.RegexOptions.IgnoreCase)&#xA;    Dim dt As New System.Data.DataTable()&#xA;    dt.Columns.Add(&quot;No Invoice&quot;, GetType(String))&#xA;    dt.Columns.Add(&quot;Tanggal&quot;, GetType(String))&#xA;    dt.Columns.Add(&quot;Vendor&quot;, GetType(String))&#xA;    dt.Columns.Add(&quot;Deskripsi&quot;, GetType(String))&#xA;    dt.Columns.Add(&quot;Qty&quot;, GetType(String))&#xA;    dt.Columns.Add(&quot;Harga Satuan&quot;, GetType(String))&#xA;    dt.Columns.Add(&quot;Total&quot;, GetType(String))&#xA;    dt.Columns.Add(&quot;Status&quot;, GetType(String))&#xA;    For Each m As System.Text.RegularExpressions.Match In matches&#xA;        Dim desk As String = m.Groups(2).Value.Trim&#xA;        Dim qty As String = m.Groups(3).Value.Trim&#xA;        Dim harga As String = m.Groups(5).Value.Replace(&quot;,&quot;, &quot;&quot;).Replace(&quot;.&quot;, &quot;&quot;).Trim&#xA;        Dim total As String = m.Groups(6).Value.Replace(&quot;,&quot;, &quot;&quot;).Replace(&quot;.&quot;, &quot;&quot;).Trim&#xA;        If desk.ToLower &lt;&gt; &quot;deskripsi&quot; Then&#xA;            dt.Rows.Add(noInvoice, tanggal, vendor, desk, qty, harga, total, &quot;Belum Bayar&quot;)&#xA;        End If&#xA;    Next&#xA;    lineItems = dt&#xA;    Console.WriteLine(&quot;Parsing selesai. Total item: &quot; &amp; dt.Rows.Count.ToString)&#xA;Catch ex As Exception&#xA;    Console.WriteLine(&quot;ERROR: &quot; &amp; ex.Message)&#xA;    lineItems = New System.Data.DataTable()&#xA;End Try" DisplayName="Invoke Code" sap:VirtualizedContainerService.HintSize="486.4,196.8" sap2010:WorkflowViewState.IdRef="InvokeCode_2">
